# HTTP port (default: 8080)
PORT=8080

# Single connection string (preferred in Docker / production)
# Example for local Postgres:
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/portifolio?sslmode=disable
DATABASE_URL=postgres://postgres:postgres@localhost:5432/portifolio?sslmode=disable

# If DATABASE_URL is unset, the app builds the URL from the variables below (defaults suit local dev).
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=portifolio
DB_SSLMODE=disable

# slog: debug | info | warn | error (default: info)
LOG_LEVEL=info

# ulule/limiter format, e.g. 100 requests per minute per IP; empty, 0, or off disables limiting
RATE_LIMIT=100-M

# Optional. Comma-separated browser origins for CORS (e.g. https://your-site.com). Empty = allow any origin (*).
# CORS_ORIGINS=

# Optional. When set, enables GET /api/v1/admin/status (use X-Admin-Key or Authorization: Bearer).
# Leave empty to omit the admin route group until you need a dashboard API.
 ADMIN_API_KEY=9876543210

# Reserved for future adapters (unread by the app today):
# SMTP_HOST=  MAIL_API_KEY=  REDIS_ADDR=  QUEUE_URL=
# AI_PROVIDER=  AI_MODEL=  AI_API_KEY=
# IP_GEO_SALT=  (for visit hashing)
