# Copy to `.env` in this directory (optional). Compose loads it when you use
# `docker compose -f infra/docker/docker-compose.yml` from the repo root.

# Browser-visible API URL baked into the SPA at **image build** time (Vite).
# Default in compose matches `app` published on the host as http://localhost:8080.
# Use the public origin the user’s browser will call (scheme + host + port).
VITE_API_BASE_URL=http://localhost:8080
