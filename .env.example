# HTTP port (default: 8080)
PORT=8080

# Single connection string (preferred in Docker / production)
# Example for local Postgres:
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/portifolio?sslmode=disable
DATABASE_URL=

# If DATABASE_URL is unset, the app builds the URL from the variables below (defaults suit local dev).
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=portifolio
DB_SSLMODE=disable

# slog: debug | info | warn | error (default: info)
LOG_LEVEL=info

# ulule/limiter format, e.g. 100 requests per minute per IP; empty, 0, or off disables limiting
RATE_LIMIT=100-M
